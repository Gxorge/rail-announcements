{
  "name": "rail-announcements-next",
  "version": "1.0.0",
  "private": true,
  "description": "Rail Announcements (Next.js)",
  "author": "David Wheatley",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "STATIC_EXPORT=true next build --webpack && next-sitemap",
    "start": "npx serve out",
    "export": "STATIC_EXPORT=true next build --webpack && next-sitemap",
    "build:ci": "STATIC_EXPORT=true next build --webpack && next-sitemap",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,less}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md,less}\"",
    "cf-typegen": "wrangler types --path='./functions/types.d.ts'",
    "serve-audio": "http-server ./audio/ -c-1 --port 8088 --cors",
    "develop:workers": "wrangler pages dev --port 8787"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/server": "^11.11.0",
    "@emotion/styled": "^11.14.1",
    "@hello-pangea/dnd": "^18.0.1",
    "@reach/tabs": "^0.18.0",
    "@sentry/nextjs": "^10.42.0",
    "clsx": "^2.1.1",
    "copy-to-clipboard": "^3.3.3",
    "crunker": "^2.4.0",
    "dayjs": "^1.11.19",
    "jotai": "^2.18.0",
    "jotai-family": "^1.0.1",
    "mdi-react": "^9.4.0",
    "nanoid": "^5.1.6",
    "next": "^16.1.6",
    "notistack": "^3.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-fullscreen-crossbrowser": "^1.1.3",
    "react-select": "^5.10.2",
    "uk-railway-stations": "^1.8.4",
    "use-html-dialog": "^0.2.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260307.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "next-sitemap": "^4.2.3",
    "null-loader": "^4.0.1",
    "prettier": "^3.8.1",
    "sass": "^1.97.3",
    "typescript": "^5.9.3",
    "wrangler": "^4.71.0"
  },
  "packageManager": "yarn@4.13.0",
  "resolutions": {
    "react": "^19",
    "react-dom": "^19",
    "@types/react-dom": "^19.2.3"
  }
}
